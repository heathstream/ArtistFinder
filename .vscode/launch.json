{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [

        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch Chrome against localhost",
            "url": "http://localhost:8080",
            "webRoot": "${workspaceFolder}"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "node.js debugging",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/${relativeFile}"
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Chrome index.html",
            "url": "http://localhost:5500/${relativeFileDirname}/index.html",
            "webRoot": "${workspaceFolder}"
        }
        ,
        {
            "type": "chrome",
            "request": "launch",
            "name": "Chrome artists.html",
            "url": "http://localhost:5500/${relativeFileDirname}/artists.html",
            "webRoot": "${workspaceFolder}"
        }
        ,
        {
            "type": "chrome",
            "request": "launch",
            "name": "Chrome addnew.html",
            "url": "http://localhost:5500/${relativeFileDirname}/addnew.html",
            "webRoot": "${workspaceFolder}"
        }
        ,
        {
            "type": "chrome",
            "request": "launch",
            "name": "Chrome details.html",
            "url": "http://localhost:5500/${relativeFileDirname}/details.html",
            "webRoot": "${workspaceFolder}"
        }
    ]
}